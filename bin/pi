#!/usr/bin/env bash
set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}")"
script_dir="$(cd -- "$(dirname -- "$script_path")" && pwd)"
# shellcheck source=pi-launch-lib
source "$script_dir/pi-launch-lib"
real_pi="$(resolve_real_pi)"

safe_env=(
  "HOME=${HOME:?HOME is required}"
  "PATH=${PATH:-/usr/local/bin:/usr/bin:/bin}"
  "PI_SANDBOX_LAUNCH=1"
)

for name in USER LOGNAME SHELL TERM COLORTERM LANG LANGUAGE LC_ALL LC_CTYPE TZ NO_COLOR FORCE_COLOR DISPLAY WAYLAND_DISPLAY XDG_RUNTIME_DIR HYPRLAND_INSTANCE_SIGNATURE DBUS_SESSION_BUS_ADDRESS PI_HOME PI_CODING_AGENT_DIR PI_MCP_ACCESS_GUARD_CONFIGS PI_MCP_ACCESS_GUARD_CACHE PI_MCP_ACCESS_RULES PI_MCP_PROMPT_BLOCK_CONFIGS PI_COMBINATIONS_DIRS PI_BWRAP_PATH; do
  if [[ -v "$name" ]]; then safe_env+=("$name=${!name}"); fi
done

exec env -i "${safe_env[@]}" "$real_pi" "$@"
