{
  "name": "pi-agent-extensions",
  "description": "Local Pi coding-agent extensions, skills, prompts, and development tooling.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "knip": "knip --include files,dependencies",
    "ci": "pnpm biome && pnpm knip && pnpm test",
    "precommit": "pnpm run ci",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^20.19.0",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
